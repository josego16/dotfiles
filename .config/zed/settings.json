// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)

{
  // ─────────────────────────────────────────────────────────────
  // AGENT & AI
  // ─────────────────────────────────────────────────────────────
  "context_servers": {
    "mcp-server-context7": {
      "enabled": true,
      "remote": false,
      "settings": {
        "context7_api_key": "ctx7sk-32483b4a-67ca-406c-b34b-71b06a2544bb",
      },
    },
  },
  "agent": {
    "default_model": {
      "provider": "opencode",
      "model": "free/minimax-m2.5-free",
      "enable_thinking": false,
    },
    "favorite_models": [],
    "model_parameters": [],
  },
  "language_models": {
    "opencode": {
      "show_zen_models": false,
      "show_go_models": false,
    },
  },
  "edit_predictions": {
    "provider": "zed",
  },

  // ─────────────────────────────────────────────────────────────
  // APPEARANCE
  // ─────────────────────────────────────────────────────────────
  "theme": {
    "mode": "dark",
    "light": "Tokyo Night Light",
    "dark": "Tokyo Night",
  },
  "icon_theme": "Material Icon Theme",
  "tab_bar": {
    "show_nav_history_buttons": false,
    "show_tab_bar_buttons": false,
  },
  "title_bar": {
    "show_menus": true,
    "show_user_menu": false,
    "show_user_picture": false,
    "show_branch_name": false,
    "show_project_items": false,
    "show_onboarding_banner": false,
  },
  "status_bar": {
    "experimental.show": false,
  },
  "toolbar": {
    "code_actions": true,
    "breadcrumbs": false,
    "quick_actions": false,
  },
  "gutter": {
    "bookmarks": false,
    "breakpoints": false,
    "runnables": false,
    "folds": false,
    "min_line_number_digits": 0,
  },
  "scrollbar": {
    "show": "never",
  },
  "minimap": {
    "display_in": "all_editors",
    "show": "always",
  },
  "tabs": {
    "file_icons": true,
    "git_status": true,
  },

  // ─────────────────────────────────────────────────────────────
  // FONTS
  // ─────────────────────────────────────────────────────────────
  "ui_font_family": ".ZedMono",
  "ui_font_size": 16,
  "buffer_font_family": "Iosevka Nerd Font Mono",
  "buffer_font_size": 16,
  "agent_ui_font_size": 16,
  "agent_buffer_font_size": 16,

  // ─────────────────────────────────────────────────────────────
  // EDITOR
  // ─────────────────────────────────────────────────────────────
  "base_keymap": "VSCode",
  "tab_size": 2,
  "multi_cursor_modifier": "cmd_or_ctrl",
  "selection_highlight": false,
  "current_line_highlight": "none",
  "show_whitespaces": "none",
  "horizontal_scroll_margin": 1,
  "vertical_scroll_margin": 1,
  "indent_guides": {
    "coloring": "indent_aware",
    "background_coloring": "indent_aware",
  },
  "colorize_brackets": true,
  "lsp_document_colors": "border",
  "code_lens": "on",
  "inlay_hints": {
    "enabled": true,
  },
  "extend_comment_on_newline": false,
  "drag_and_drop_selection": {
    "enabled": false,
  },
  "seed_search_query_from_cursor": "never",

  // ─────────────────────────────────────────────────────────────
  // PANELS
  // ─────────────────────────────────────────────────────────────
  "git_panel": {
    "file_icons": true,
    "tree_view": true,
  },
  "project_panel": {
    "auto_open": {
      "on_drop": false,
      "on_paste": false,
      "on_create": true,
    },
    "hide_root": true,
    "indent_guides": {
      "show": "never",
    },
    "default_width": 400,
    "dock": "right",
  },
  "outline_panel": {
    "default_width": 400,
    "indent_guides": {
      "show": "never",
    },
  },
  "file_finder": {
    "modal_max_width": "large",
  },
  "centered_layout": {
    "left_padding": 0.15,
    "right_padding": 0.15,
  },

  // ─────────────────────────────────────────────────────────────
  // AUTOSAVE & SESSIONS
  // ─────────────────────────────────────────────────────────────
  "autosave": {
    "after_delay": {
      "milliseconds": 1000,
    },
  },
  "when_closing_with_no_tabs": "platform_default",
  "close_on_file_delete": true,
  "restore_on_file_reopen": false,
  "restore_on_startup": "launchpad",
  "session": {
    "trust_all_worktrees": true,
    "restore_unsaved_buffers": false,
  },

  // ─────────────────────────────────────────────────────────────
  // GIT
  // ─────────────────────────────────────────────────────────────
  "git": {
    "git_gutter": "hide",
    "inline_blame": {
      "padding": 5,
      "enabled": false,
    },
  },

  // ─────────────────────────────────────────────────────────────
  // TERMINAL
  // ─────────────────────────────────────────────────────────────
  "terminal": {
    "copy_on_select": true,
    "font_family": "CaskaydiaCove Nerd Font",
    "shell": {
      "program": "/usr/bin/zsh",
    },
  },

  // ─────────────────────────────────────────────────────────────
  // LANGUAGE SERVERS & FORMATTERS
  // ─────────────────────────────────────────────────────────────

  "lsp": {
    "oxlint": {
      "initialization_options": {
        "settings": {
          "configPath": null,
          "run": "onType",
          "disableNestedConfig": false,
          "fixKind": "safe_fix",
          "unusedDisableDirectives": "deny",
        },
      },
    },
    "oxfmt": {
      "initialization_options": {
        "settings": {
          "fmt.configPath": null,
          "run": "onSave",
        },
      },
    },
    "gopls": {
      "initialization_options": {
        "staticcheck": true,
        "analyses": {
          "nilness": true,
          "unusedwrite": true,
          "shadow": true,
          "useany": true,
        },
        "codelenses": {
          "test": true,
          "generate": true,
          "regenerate_cgo": true,
          "tidy": true,
          "upgrade_dependency": true,
          "vendor": true,
        },
        "hints": {
          "assignVariableTypes": true,
          "compositeLiteralFields": true,
          "compositeLiteralTypes": true,
          "constantValues": true,
          "functionTypeParameters": true,
          "parameterNames": true,
          "rangeVariableTypes": true,
        },
      },
    },
    "golangci-lint": {
      "initialization_options": {
        "command": [
          "golangci-lint",
          "run",
          "--output.json.path",
          "stdout",
          "--show-stats=false",
          "--output.text.path=",
        ],
      },
    },
  },

  "languages": {
    "JavaScript": {
      "format_on_save": "on",
      "prettier": {
        "allowed": false,
      },
      "formatter": [
        {
          "language_server": {
            "name": "oxfmt",
          },
        },
        {
          "code_action": "source.fixAll.oxc",
        },
      ],
    },
    "TypeScript": {
      "format_on_save": "on",
      "prettier": {
        "allowed": false,
      },
      "formatter": [
        {
          "language_server": {
            "name": "oxfmt",
          },
        },
      ],
    },
    "Go": {
      "language_servers": ["gopls", "golangci-lint"],
      "inlay_hints": {
        "enabled": true,
      },
    },
  },

  "auto_install_extensions": {
    "astro": true,
    "autocorrect": true,
    "codebook": true,
    "comment": true,
    "csv": true,
    "docker-compose": true,
    "dockerfile": true,
    "emmet": true,
    "git-firefly": true,
    "golangci-lint": true,
    "html": true,
    "html-snippets": true,
    "javascript-snippets": true,
    "live-server": true,
    "live-template": true,
    "material-icon-theme": true,
    "mcp-server-context7": true,
    "mdx": true,
    "oxc": true,
    "php": true,
    "prisma": true,
    "proto": true,
    "rainbow-csv": true,
    "sql": true,
    "sqlc-snippets": true,
    "tokyo-night": true,
    "typescript-snippets": true,
    "xml": true,
  },
  "auto_update_extensions": {
    "astro": true,
    "autocorrect": true,
    "codebook": true,
    "comment": true,
    "csv": true,
    "docker-compose": true,
    "dockerfile": true,
    "emmet": true,
    "git-firefly": true,
    "golangci-lint": true,
    "html": true,
    "html-snippets": true,
    "javascript-snippets": true,
    "live-server": true,
    "live-template": true,
    "material-icon-theme": true,
    "mcp-server-context7": true,
    "mdx": true,
    "oxc": true,
    "php": true,
    "prisma": true,
    "proto": true,
    "rainbow-csv": true,
    "sql": true,
    "sqlc-snippets": true,
    "tokyo-night": true,
    "typescript-snippets": true,
    "xml": true,
  },

  // ─────────────────────────────────────────────────────────────
  // TELEMETRY
  // ─────────────────────────────────────────────────────────────
  "telemetry": {
    "diagnostics": false,
    "metrics": false,
  },
}
