// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)

{
  // ─────────────────────────────────────────────────────────────
  // AGENT & AI
  // ─────────────────────────────────────────────────────────────
  "agent": {
    "default_model": {
      "provider": "opencode",
      "model": "free/minimax-m2.5-free",
      "enable_thinking": true,
    },
    "favorite_models": [],
    "model_parameters": [],
  },
  "agent_servers": {
    "opencode": {
      "type": "registry",
    },
  },
  "language_models": {
    "opencode": {
      "show_zen_models": false,
      "show_go_models": false,
    },
  },
  "edit_predictions": {
    "allow_data_collection": "default",
    "mode": "eager",
    "provider": "zed",
  },

  // ─────────────────────────────────────────────────────────────
  // APPEARANCE
  // ─────────────────────────────────────────────────────────────
  "theme": {
    "mode": "system",
    "light": "Snazzy Theme - blurred",
    "dark": "Snazzy Theme - blurred",
  },
  "theme_overrides": {
    "Snazzy Theme - blurred": {
      "border.variant": "#282a36ee",
      "border": "#282a36ee",
      "title_bar.background": "#282a36ee",
      "panel.background": "#282a36ee",
      "syntax": {
        "comment": {
          "font_style": "italic",
        },
        "comment_doc": {
          "font_style": "italic",
        },
      },
    },
  },
  "icon_theme": "Material Icon Theme",
  "tab_bar": {
    "show_nav_history_buttons": false,
    "show_tab_bar_buttons": false,
  },
  "title_bar": {
    "show_menus": true,
    "show_user_menu": false,
    "show_user_picture": false,
    "show_branch_name": false,
    "show_project_items": false,
    "show_onboarding_banner": false,
  },
  "status_bar": {
    "experimental.show": false,
  },
  "toolbar": {
    "code_actions": true,
    "breadcrumbs": false,
    "quick_actions": false,
  },
  "gutter": {
    "bookmarks": false,
    "breakpoints": false,
    "runnables": false,
    "folds": false,
    "min_line_number_digits": 0,
  },
  "scrollbar": {
    "show": "never",
  },
  "minimap": {
    "display_in": "all_editors",
    "show": "always",
  },
  "tabs": {
    "file_icons": true,
    "git_status": true,
  },

  // ─────────────────────────────────────────────────────────────
  // FONTS
  // ─────────────────────────────────────────────────────────────
  "ui_font_family": ".ZedMono",
  "ui_font_size": 16,
  "buffer_font_family": "Iosevka Nerd Font Mono",
  "buffer_font_size": 16,
  "agent_ui_font_size": 16,
  "agent_buffer_font_size": 16,

  // ─────────────────────────────────────────────────────────────
  // EDITOR
  // ─────────────────────────────────────────────────────────────
  "base_keymap": "VSCode",
  "tab_size": 2,
  "multi_cursor_modifier": "cmd_or_ctrl",
  "selection_highlight": false,
  "current_line_highlight": "none",
  "show_whitespaces": "none",
  "horizontal_scroll_margin": 1,
  "vertical_scroll_margin": 1,
  "indent_guides": {
    "coloring": "indent_aware",
    "background_coloring": "indent_aware",
  },
  "colorize_brackets": true,
  "code_lens": "on",
  "inline_code_actions": false,
  "hover_popover_enabled": false,
  "inlay_hints": {
    "enabled": false,
  },
  "extend_comment_on_newline": false,
  "drag_and_drop_selection": {
    "enabled": false,
  },
  "seed_search_query_from_cursor": "never",

  // ─────────────────────────────────────────────────────────────
  // PANELS
  // ─────────────────────────────────────────────────────────────
  "git_panel": {
    "file_icons": true,
    "tree_view": true,
  },
  "project_panel": {
    "auto_open": {
      "on_drop": false,
      "on_paste": false,
      "on_create": true,
    },
    "hide_root": true,
    "indent_guides": {
      "show": "never",
    },
    "default_width": 400.0,
    "dock": "right",
  },
  "outline_panel": {
    "default_width": 400,
    "indent_guides": {
      "show": "never",
    },
  },
  "file_finder": {
    "modal_max_width": "large",
  },
  "centered_layout": {
    "left_padding": 0.15,
    "right_padding": 0.15,
  },

  // ─────────────────────────────────────────────────────────────
  // AUTOSAVE & SESSIONS
  // ─────────────────────────────────────────────────────────────
  "autosave": {
    "after_delay": {
      "milliseconds": 1000,
    },
  },
  "when_closing_with_no_tabs": "platform_default",
  "close_on_file_delete": true,
  "restore_on_file_reopen": false,
  "restore_on_startup": "launchpad",
  "session": {
    "trust_all_worktrees": true,
    "restore_unsaved_buffers": false,
  },

  // ─────────────────────────────────────────────────────────────
  // GIT
  // ─────────────────────────────────────────────────────────────
  "git": {
    "git_gutter": "hide",
    "blame": {},
    "inline_blame": {
      "padding": 5,
      "enabled": false,
    },
  },

  // ─────────────────────────────────────────────────────────────
  // TERMINAL
  // ─────────────────────────────────────────────────────────────
  "terminal": {
    "copy_on_select": true,
    "font_family": "CaskaydiaCove Nerd Font",
    "shell": {
      "program": "/usr/bin/zsh",
    },
  },

  // ─────────────────────────────────────────────────────────────
  // LANGUAGE SERVERS & FORMATTERS
  // ─────────────────────────────────────────────────────────────
  "lsp": {
    "eslint": {
      "settings": {
        "codeActionOnSave": {
          "rules": ["import/order"],
        },
      },
    },
  },
  "prettier": {
    "allowed": true,
  },
  "languages": {
    "Go": {
      "code_actions_on_format": {
        "source.organizeImports": true,
      },
    },
    "TypeScript": {
      "formatter": {
        "external": {
          "command": "prettier",
          "arguments": ["--stdin-filepath", "{buffer_path}"],
        },
      },
      "code_actions_on_format": {
        "source.organizeImports": true,
        "source.fixAll.eslint": true,
      },
    },
    "TSX": {
      "formatter": {
        "external": {
          "command": "prettier",
          "arguments": ["--stdin-filepath", "{buffer_path}"],
        },
      },
      "code_actions_on_format": {
        "source.organizeImports": true,
        "source.fixAll.eslint": true,
      },
    },
    "JavaScript": {
      "formatter": {
        "external": {
          "command": "prettier",
          "arguments": ["--stdin-filepath", "{buffer_path}"],
        },
      },
      "code_actions_on_format": {
        "source.fixAll.eslint": true,
      },
    },
  },

  // ─────────────────────────────────────────────────────────────
  // TELEMETRY
  // ─────────────────────────────────────────────────────────────
  "telemetry": {
    "diagnostics": false,
    "metrics": false,
  },
}
