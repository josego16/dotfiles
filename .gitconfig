[user]
	name = josemagomezz
	email = josemagomez.devs@gmail.com
	username = josego16
	signingkey = /home/josedev/.ssh/id_ed25519.pub
[init]
    defaultBranch = main
[pull]
	rebase = true
[core]
	editor = zed
	excludesFile = $HOME/.gitignore_global
[commit]
	verbose = true
	gpgsign = true
[url "ssh://git@github.com"]
    insteadOf = https://github.com
[color]
	ui = auto
[fetch]
	prune = true
[rebase]
	autoStash = true
	autosquash = true
	updateRefs = true
[push]
	useForceIfIncludes = true
	autoSetupRemote = true
[rerere]
	enabled = true
[gpg]
	format = ssh
[gpg "ssh"]
	allowedSignersFile = $HOME.config/git/allowed_signers
[branch "main"]
	rebase = true
[diff]
	algorithm = histogram
